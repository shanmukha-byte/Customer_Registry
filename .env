# The port your backend server will run on
PORT=5000

# The connection string for your MongoDB database
# (If you are using a local MongoDB installation, use the string below)
MONGODB_URI=mongodb://localhost:27017/customerDB

# (Optional) If you use MongoDB Atlas in the future, you would replace it with:
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/customerDB